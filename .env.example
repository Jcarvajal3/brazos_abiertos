# ─────────────────────────────────────────────────────────────────────────────
# Brazos Abiertos con Venezuela — Variables de Entorno
# Copia este archivo a .env.local y rellena con tus valores reales.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtén estos valores en: https://supabase.com/dashboard → Settings → API
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key (NUNCA en el cliente, solo server-side)
# Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Stripe ────────────────────────────────────────────────────────────────────
# Obtén estas claves en: https://dashboard.stripe.com/apikeys
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Clave secreta (NUNCA en el cliente)
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Webhook secret: se genera al crear un webhook endpoint en el dashboard de Stripe
# URL del webhook: https://tu-dominio.vercel.app/api/stripe/webhook
# Eventos a escuchar: payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─────────────────────────────────────────────────────────────────────────────
# PASOS PARA DEPLOYMENT EN VERCEL:
# 1. Conecta tu repositorio en vercel.com
# 2. Agrega TODAS las variables de arriba en Settings → Environment Variables
# 3. En Stripe Dashboard → Webhooks → Add Endpoint:
#    URL: https://tu-app.vercel.app/api/stripe/webhook
#    Eventos: payment_intent.succeeded, payment_intent.payment_failed
# 4. Copia el Signing Secret generado como STRIPE_WEBHOOK_SECRET
# 5. En Supabase SQL Editor, ejecuta:
#    SELECT set_admin_role('UUID_DEL_USUARIO_ADMIN');
# ─────────────────────────────────────────────────────────────────────────────
