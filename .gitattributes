# Normalize line endings for all text files
* text=auto eol=lf

# Explicitly declare text files
*.ts text eol=lf
*.svelte text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.sql text eol=lf
*.md text eol=lf
*.env.example text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text eol=lf
